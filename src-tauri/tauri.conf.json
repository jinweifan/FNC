{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "First NC Viewer",
  "mainBinaryName": "First NC Viewer",
  "version": "0.1.0",
  "identifier": "com.fncviewer.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "First NC Viewer",
        "width": 1600,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "visible": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "bundleName": "First NC Viewer",
      "infoPlist": "Info.plist"
    },
    "linux": {
      "deb": {
        "desktopTemplate": "linux/FNCViewer.desktop",
        "files": {
          "/usr/share/mime/packages/fncviewer.xml": "linux/fncviewer.xml"
        },
        "postInstallScript": "linux/postinst.sh",
        "postRemoveScript": "linux/postrm.sh"
      }
    },
    "fileAssociations": [
      {
        "ext": [
          "nc",
          "anc"
        ],
        "name": "NC Program",
        "description": "Numerical Control Program File",
        "role": "Editor",
        "mimeType": "application/x-fncviewer-nc"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
