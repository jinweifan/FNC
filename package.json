{
  "name": "first-nc-viewer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "tauri": "node ./node_modules/@tauri-apps/cli/tauri.js",
    "tauri:dev": "node ./node_modules/@tauri-apps/cli/tauri.js dev",
    "tauri:build": "node ./node_modules/@tauri-apps/cli/tauri.js build",
    "tauri:build:win": "node ./scripts/package-platform.mjs win",
    "tauri:build:linux": "node ./scripts/package-platform.mjs linux",
    "tauri:build:mac:intel": "node ./scripts/package-platform.mjs mac:intel",
    "tauri:build:mac:arm": "node ./scripts/package-platform.mjs mac",
    "package:linux": "node ./scripts/package-platform.mjs linux",
    "package:linux:docker": "bash ./scripts/package-linux-docker.sh",
    "package:mac": "node ./scripts/package-platform.mjs mac",
    "package:mac:intel": "node ./scripts/package-platform.mjs mac:intel",
    "package:win": "node ./scripts/package-platform.mjs win",
    "test:packaging": "node --test scripts/package-platform.test.mjs scripts/desktop-workflow.test.mjs scripts/package-manifest.test.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "i18next": "^25.9.0",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
